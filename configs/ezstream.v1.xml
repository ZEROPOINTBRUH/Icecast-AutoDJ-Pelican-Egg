<ezstream>
        <servers>
                <server>
                        <protocol>HTTP</protocol>
                        <hostname>localhost</hostname>
                        <port>8000</port>
                        <user>source</user>
                        <password>autodjpassword123</password>
                        <reconnect_attempts>0</reconnect_attempts>
                </server>
        </servers>

        <streams>
                <stream>
                        <mountpoint>/autodj</mountpoint>
                        <format>MP3</format>
                        <encoder>MP3-128</encoder>
                        <public>0</public>
                        <stream_name>AutoDJ Radio</stream_name>
                        <stream_url>http://localhost:8000/autodj</stream_url>
                        <stream_genre>Various</stream_genre>
                        <stream_description>The AutoDJ Stream</stream_description>
                </stream>
        </streams>

        <intakes>
                <intake>
                        <type>playlist</type>
                        <filename>/home/container/playlist.m3u</filename>
                        <shuffle>1</shuffle>
                        <stream_once>0</stream_once>
                </intake>
        </intakes>

        <decoders>
                <decoder>
                        <name>FFMPEG-Universal</name>
                        <program>ffmpeg -i @T@ -f wav -acodec pcm_s16le -ar 44100 -ac 2 -</program>
                        <file_ext>.mp3</file_ext>
                        <file_ext>.m4a</file_ext>
                        <file_ext>.aac</file_ext>
                        <file_ext>.ogg</file_ext>
                        <file_ext>.flac</file_ext>
                        <file_ext>.opus</file_ext>
                        <file_ext>.wav</file_ext>
                        <file_ext>.wma</file_ext>
                </decoder>
        </decoders>

        <encoders>
                <encoder>
                        <name>MP3-128</name>
                        <format>MP3</format>
                        <program>lame --preset cbr 128 -r -s 44.1 --bitwidth 16 - -</program>
                </encoder>
        </encoders>
</ezstream>
