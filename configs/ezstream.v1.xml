<ezstream>
        <servers>
                <server>
                        <protocol>HTTP</protocol>
                        <hostname>localhost</hostname>
                        <port>8000</port>
                        <user>source</user>
                        <password>autodjpassword</password>
                        <reconnect_attempts>0</reconnect_attempts>
                </server>
        </servers>

        <streams>
                <stream>
                        <mountpoint>/autodj</mountpoint>
                        <public>0</public>
                        <stream_name>AutoDJ Radio</stream_name>
                        <stream_url>http://localhost:8000/autodj</stream_url>
                        <stream_genre>Various</stream_genre>
                        <stream_description>The AutoDJ Stream</stream_description>
                </stream>
        </streams>

        <intakes>
                <intake>
                        <type>playlist</type>
                        <filename>/home/container/playlist.m3u</filename>
                        <shuffle>1</shuffle>
                        <stream_once>0</stream_once>
                </intake>
        </intakes>
</ezstream>
