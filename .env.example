# AutoDJ-Extreme Environment Configuration Template
# ═══════════════════════════════════════════════════════════════════════════════════════════════
# 
# INSTRUCTIONS:
# 1. Copy this file to .env: cp .env.example .env
# 2. Update all values for your deployment
# 3. NEVER commit .env to git (it contains passwords)
# 4. Run: ./scripts/generate-configs.sh to generate all configs from this file
# 5. Restart services: docker restart autodj OR systemctl restart icecast2
#
# ⚠️  SECURITY CRITICAL:
# • Change ALL default passwords immediately
# • Use 16+ character passwords with mixed case, numbers, symbols
# • Use different passwords for each service
# • Restrict file permissions: chmod 600 .env
# ═══════════════════════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────────────────────
# 🔐 SECURITY CREDENTIALS - CHANGE THESE IMMEDIATELY!
# ─────────────────────────────────────────────────────────────────────────────────────────────
# 
# Best practice: Generate strong passwords with:
#   openssl rand -base64 16
#   -join ((65..90) + (97..122) + (48..57) | Get-Random -Count 16 | % {[char]$_})
#

# Admin panel username
ADMIN_USER=admin

# Admin panel password (min 12 characters, mix of upper/lower/numbers/symbols)
# Examples: Str0ng!Pass#123, MyAdm1n@SecureP@ss, 4DM!nP@ssw0rd
ADMIN_PASSWORD=adminpassword123

# Icecast source streaming password (used by Liquidsoap/ezstream to send streams)
# This is critical - protects your streaming input
SOURCE_PASSWORD=autodjpassword123

# Relay server password (for relay/backup servers)
RELAY_PASSWORD=relaypassword123

# AutoDJ mount point password
# Used if AUTODJ_PUBLIC=0 (private stream)
AUTODJ_PASSWORD=autodjpassword123

# Live streaming mount point password
# Used if LIVE_PUBLIC=0 (private stream)
LIVE_PASSWORD=livepassword123

# Stream/relay mount point password
# Used if STREAM_PUBLIC=0 (private stream)
STREAM_PASSWORD=streampassword123

# ─────────────────────────────────────────────────────────────────────────────────────────────
# 📡 NETWORK CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────────────────────

# Icecast server hostname/IP (localhost for local, 0.0.0.0 for Docker)
ICECAST_HOST=localhost

# Icecast listening port (default 8000)
# Common alternatives: 80 (HTTP), 443 (HTTPS via reverse proxy), 3000, 8080
ICECAST_PORT=8000

# Maximum concurrent clients (0 = unlimited)
# Adjust based on bandwidth: 1Mbps ≈ 8 listeners at 128kbps
ICECAST_MAX_CLIENTS=0

# Burst size for connection startup (bytes)
# Default 65535 is good; adjust if connection issues
ICECAST_BURST_SIZE=65535

# ─────────────────────────────────────────────────────────────────────────────────────────────
# 🎵 STREAM CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────────────────────

# Public/Private Access Settings
# 1 = Public (no authentication required - anyone can listen)
# 0 = Private (requires password specified above)

# AutoDJ stream (primary auto-rotating playlist)
AUTODJ_PUBLIC=1

# Live stream (for live input via source)
LIVE_PUBLIC=0

# Relay/Stream mount point
STREAM_PUBLIC=1

# Audio Bitrate Configuration (kbps)
# 96  = Lower quality, uses less bandwidth
# 128 = Standard quality, recommended
# 192 = Higher quality, more bandwidth
# 256 = High quality, significantly more bandwidth
MP3_BITRATE=128
OGG_BITRATE=128

# ─────────────────────────────────────────────────────────────────────────────────────────────
# 🎼 CONTENT CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────────────────────

# Directory paths (mount paths in Docker/container)
MUSIC_DIR=/home/container/music
PLAYLIST_DIR=/home/container/playlists
ADS_DIR=/home/container/ads
JINGLES_DIR=/home/container/jingles
LOG_DIR=/home/container/log

# Feature flags
ENABLE_ADS=false
AD_FREQUENCY=5          # Play ad every N tracks (5 means every 5 tracks)

ENABLE_JINGLES=false
JINGLE_FREQUENCY=3      # Play jingle every N tracks

ENABLE_LIQUIDSOAP=true  # Use Liquidsoap (recommended) vs ezstream

# ─────────────────────────────────────────────────────────────────────────────────────────────
# 📊 LOGGING & MONITORING
# ─────────────────────────────────────────────────────────────────────────────────────────────

# Log level (0=critical, 1=error, 2=warn, 3=info, 4=debug)
# Use 3 for production, 4 for debugging
LOG_LEVEL=3

# Process monitoring interval (seconds)
# How often to check if services are running and auto-restart if needed
MONITOR_INTERVAL=30

# ─────────────────────────────────────────────────────────────────────────────────────────────
# 🌍 METADATA & HOSTING INFORMATION
# ─────────────────────────────────────────────────────────────────────────────────────────────

# Station name (displayed in Icecast directory listings)
STATION_NAME=AutoDJ-Extreme

# Station description
STATION_DESCRIPTION=Professional Radio

# Station physical location (for Icecast YP directory)
STATION_LOCATION=Earth

# Administrator email (for station listings)
ADMIN_EMAIL=admin@example.com

# ═════════════════════════════════════════════════════════════════════════════════════════════
# DEPLOYMENT EXAMPLES
# ═════════════════════════════════════════════════════════════════════════════════════════════
#
# DOCKER COMPOSE:
# ───────────────
# version: '3.8'
# services:
#   autodj:
#     image: ghcr.io/zeropointbruh/icecast-autodj:latest
#     ports:
#       - "8000:8000"
#       - "8080:8080"
#     volumes:
#       - ./music:/home/container/music
#       - ./logs:/home/container/log
#     env_file: .env
#     restart: unless-stopped
#
# DOCKER CLI:
# ───────────
# docker run -d \
#   --name autodj \
#   -p 8000:8000 -p 8080:8080 \
#   --env-file .env \
#   -v ./music:/home/container/music \
#   -v ./logs:/home/container/log \
#   ghcr.io/zeropointbruh/icecast-autodj:latest
#
# ═════════════════════════════════════════════════════════════════════════════════════════════
